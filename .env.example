# Copy this file to ".env" and fill in real values. NEVER commit ".env".
#
# Authentication cookie for api.eliis.eu. Capture it from your browser's
# DevTools (Network tab -> request -> "Cookie" header) while logged in.
# This value is sensitive — treat it like a password.
ELIIS_COOKIE="lang=et; eliis_csrf=REPLACE_WITH_YOUR_TOKEN; _ga=REPLACE"

# Optional: override the API base URL (defaults to https://api.eliis.eu).
# ELIIS_BASE_URL="https://api.eliis.eu"

# Default kindergarten / child ids (can also be passed via CLI flags).
ELIIS_KINDERGARTEN_ID="349"
ELIIS_CHILD_ID="255561"

# Optional: extra request headers as a JSON object, merged over the safe
# defaults. Do NOT put cookies/tokens here — use ELIIS_COOKIE instead.
# ELIIS_EXTRA_HEADERS={"x-custom":"value"}
